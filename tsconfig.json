        "target": "ES2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "sourceMap": true,
        "rootDir": ".src",
        "outDir": "./dist",
        "strict": true,
        "esModuleInterop": true
    },
    "ts-node": {
        "esm": true
